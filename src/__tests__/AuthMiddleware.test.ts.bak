import { describe, it, expect, beforeEach, vi } from 'vitest';
import { AuthMiddleware } from '../middleware/AuthMiddleware';
import { RoleManager } from '../services/RoleManager';
import { Role, Permission } from '../models/rbac';

// Mock Request 和 Response
class MockRequest {
  private _url: string;
  private _headers: Map<string, string>;
  private _method: string;

  constructor(url: string, method: string = 'GET', headers: Record<string, string> = {}) {
    this._url = url;
    this._method = method;
    this._headers = new Map(Object.entries(headers));
  }

  get url(): string { return this._url; }
  get method(): string { return this._method; }
  get headers(): Headers {
    const h = new Headers();
    this._headers.forEach((v, k) => h.set(k, v));
    return h;
  }
}

class MockResponse {
  status: number;
  body: string;
  headers: Record<string, string>;

  constructor(status: number, body: string, headers: Record<string, string> = {}) {
    this.status = status;
    this.body = body;
    this.headers = headers;
  }

  async text(): Promise<string> { return this.body; }
}

// Mock RoleManager
const createMockRoleManager = () => {
  return {
    hasPermission: vi.fn().mockResolvedValue(true),
    hasRole: vi.fn().mockResolvedValue(true),
  };
};

// 生成简单的 JWT token (Base64 编码的 payload)
const createToken = (payload: Record<string, any>) => {
  const header = btoa(JSON.stringify({ alg: 'HS256', typ: 'JWT' }));
  const payloadStr = btoa(JSON.stringify(payload));
  const signature = 'signature';
  return `${header}.${payloadStr}.${signature}`;
};

describe('AuthMiddleware', () => {
  let authMiddleware: AuthMiddleware;

  beforeEach(() => {
    const roleManagerInstance = {
      hasPermission: vi.fn().mockResolvedValue(true),
      hasRole: vi.fn().mockResolvedValue(true),
    } as unknown as RoleManager;

    authMiddleware = new AuthMiddleware(
      roleManagerInstance as RoleManager,
      {
        SUPABASE_URL: 'https://test.supabase.co',
        SUPABASE_ANON_KEY: 'test-anon-key',
      }
    );
  });

  // 辅助函数：创建测试请求
  const createTestRequest = (
    url: string,
    method: string = 'GET',
    headers: Record<string, string> = {}
  ) => {
    return new Request(url, { method, headers });
  };

  // 辅助函数：生成简单的 JWT token
  const createToken = (payload: Record<string, any>) => {
    const header = btoa(JSON.stringify({ alg: 'HS256', typ: 'JWT' }));
    const payloadStr = btoa(JSON.stringify(payload));
    const signature = 'signature';
    return `${header}.${payloadStr}.${signature}`;
  };

  describe('handle - missing tenant_id', () => {
    it('should return 400 when missing tenant_id', async () => {
      const request = new Request('https://api.example.com/products', {
        method: 'GET',
        headers: {
          'Authorization': `Bearer ${createToken({ sub: 'user-1' })}`,
        },
      });

      const response = await authMiddleware.handle(request as unknown as Request);
      expect(response.status).toBe(400);
      const body = await response.json();
      expect(body.error).toBe('Missing tenant_id');
    });

    it('should pass tenant_id check when provided in header', async () => {
      const request = new Request('https://api.example.com/products', {
        method: 'GET',
        headers: {
          'Authorization': `Bearer ${createToken({ sub: 'user-1' })}`,
          'x-tenant-id': 'tenant-123',
        },
      });

      const response = await authMiddleware.handle(request as unknown as Request);
      // Since there is no real Supabase backend, it may fail, but should not be 400
      expect(response.status).not.toBe(400);
    });
  });

  describe('handle - missing Authorization header', () => {
    it('should return 401 when Authorization header is missing', async () => {
      const request = new Request('https://api.example.com/products?tenant_id=tenant-123', {
        method: 'GET',
      });

      const response = await authMiddleware.handle(request as unknown as Request);
      expect(response.status).toBe(401);
      const body = await response.json();
      expect(body.error).toBe('Missing Bearer token');
    });

    it('should return 401 when Authorization format is invalid', async () => {
      const request = new Request('https://api.example.com/products?tenant_id=tenant-123', {
        method: 'GET',
        headers: { 'Authorization': 'InvalidToken' },
      });

      const response = await authMiddleware.handle(request as unknown as Request);
      expect(response.status).toBe(401);
      const body = await response.json();
      expect(body.error).toBe('Missing Bearer token');
    });
  });

  describe('handle - Token parsing', () => {
    it('should return 401 for invalid token', async () => {
      const request = new Request('https://api.example.com/products?tenant_id=tenant-123', {
        method: 'GET',
        headers: { 'Authorization': 'Bearer invalid.token.here' },
      });

      const response = await authMiddleware.handle(request as unknown as Request);
      expect(response.status).toBe(401);
      const body = await response.json();
      expect(body.error).toBe('Invalid token');
    });

    it('should return 401 for valid token without sub', async () => {
      const token = createToken({ name: 'test' }); // no sub
      const request = new Request('https://api.example.com/products?tenant_id=tenant-123', {
        method: 'GET',
        headers: { 'Authorization': `Bearer ${token}` },
      });

      const response = await authMiddleware.handle(request as unknown as Request);
      expect(response.status).toBe(401);
      const body = await response.json();
      expect(body.error).toBe('User not identified');
    });

    it('should pass token parsing with valid token', async () => {
      const token = createToken({ sub: 'user-123', role: 'ADMIN' });
      const request = new Request('https://api.example.com/products?tenant_id=tenant-123', {
        method: 'GET',
        headers: { 'Authorization': `Bearer ${token}` },
      });

      const response = await authMiddleware.handle(request as unknown as Request);
      // Here it may fail due to no real Supabase backend, but should not be 401
      expect(response.status).not.toBe(401);
    });
  });

  describe('handle - permission check', () => {
    it('should return 403 when permission is insufficient', async () => {
      // Create a RoleManager that returns false
      const roleManagerMock = {
        hasPermission: vi.fn().mockResolvedValue(false),
        hasRole: vi.fn().mockResolvedValue(true),
      } as unknown as RoleManager;

      const middleware = new AuthMiddleware(
        roleManagerMock as any,
        { SUPABASE_URL: 'https://test.supabase.co', SUPABASE_ANON_KEY: 'key' }
      );

      const token = createToken({ sub: 'user-123' });
      const request = new Request('https://api.example.com/products?tenant_id=tenant-123', {
        method: 'GET',
        headers: { 'Authorization': `Bearer ${token}` },
      );

      const response = await middleware.handle(request as unknown as Request);
      expect(response.status).toBe(403);
      const body = await response.json();
      expect(body.error).toBe('Insufficient permissions');
    });

    it('should continue processing when permission is sufficient', async () => {
      const token = createToken({ sub: 'user-123' });
      const request = new Request('https://api.example.com/products?tenant_id=tenant-123', {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}` },
      });

      const response = await authMiddleware.handle(request as unknown as Request);
      // Permission check passes (mock returns true), but fetch will fail
      expect(response.status).not.toBe(403);
    });
  });

  describe('Token parsing logic', () => {
    it('should correctly parse JWT payload', () => {
      const payload = { sub: 'user-123', role: 'ADMIN', exp: Date.now() + 3600000 };
      const token = createToken(payload);
      const parts = token.split('.');
      const decoded = JSON.parse(atob(parts[1]));

      expect(decoded.sub).toBe('user-123');
      expect(decoded.role).toBe('ADMIN');
    });

    it('should throw error for invalid token format', () => {
      expect(() => {
        const parts = 'invalid.token'.split('.');
        JSON.parse(atob(parts[1]));
      }).toThrow();
    });
  });

  describe('Request header handling', () => {
    it('should correctly extract Authorization header', async () => {
      const token = createToken({ sub: 'user-123' });
      const request = new Request('https://api.example.com/products?tenant_id=tenant-123', {
        method: 'GET',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json',
        },
      });

      const response = await authMiddleware.handle(request as unknown as Request);
      // Verify headers are correctly read (won't return 401 due to missing token)
      expect(response.status).not.toBe(401);
    });
  });
}