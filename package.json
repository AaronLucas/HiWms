{
  "name": "wms7",
  "version": "1.0.0",
  "description": "Project using Redux Toolkit and WMS workflows",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "workspaces": [
    "workflow-engine"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prebuild": "npm run build --workspace=workflow-engine",
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prelint": "npm run build --workspace=workflow-engine",
    "lint": "tsc --noEmit",
    "ci": "npm run lint && npm run test:coverage && npm run build"
  },
  "type": "module",
  "dependencies": {
    "@reduxjs/toolkit": "^2.3.0",
    "@supabase/supabase-js": "^2.110.0",
    "express": "^4.19.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.1.3",
    "wms-workflow-engine": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "@types/express": "^4.17.21",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "jest": "^29.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.6",
    "vitest": "^4.1.10"
  }
}
