{
  "name": "wms7",
  "version": "1.0.0",
  "description": "Project using Redux Toolkit and WMS workflows",
  "main": "index.js",
  "workspaces": [
    "workflow-engine"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prebuild": "npm run build --workspace=workflow-engine",
    "build": "tsc",
    "dev": "ts-node src/workflows/test-workflow.ts",
    "workflow:test": "ts-node src/workflows/test-workflow.ts",
    "prelint": "npm run build --workspace=workflow-engine",
    "lint": "tsc --noEmit",
    "ci": "npm run lint && npm run test:coverage && npm run build"
  },
  "type": "module",
  "dependencies": {
    "@reduxjs/toolkit": "^2.3.0",
    "@supabase/supabase-js": "^2.110.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.1.3",
    "wms-workflow-engine": "*"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "jest": "^29.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.6",
    "vitest": "^4.1.9"
  }
}