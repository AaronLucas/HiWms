{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["DOM", "ES2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "declaration": true,
    "outDir": "./dist",
    "jsx": "preserve",
    "noEmitOnError": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@core/*": ["src/core/*"],
      "@adapters/*": ["src/adapters/*"],
      "@apps/*": ["src/apps/*"],
      "@configs/*": ["src/configs/*"],
      "@types/*": ["src/types/*"]
    },
    "types": ["@cloudflare/workers-types", "vitest/globals"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "workflow-engine", "src/routes", "src/middleware", "src/services"]
}